# ─────────────────────────────────────────────────────────────────────────────
# 3D Printed Spare Parts — Environment Variables (EXAMPLE FILE)
# ─────────────────────────────────────────────────────────────────────────────
# This file is safe to commit to Git — it contains no real secrets.
#
# TO SET UP:
#   cp .env.example .env
#   Then open .env and replace every placeholder with your real values.
# ─────────────────────────────────────────────────────────────────────────────


# ── 1. NewsAPI ────────────────────────────────────────────────────────────────
# Sign up: https://newsapi.org/register
NEWSAPI_KEY=


# ── 2. Anthropic (Claude) API ─────────────────────────────────────────────────
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=


# ── 3. WordPress.com Site ID ──────────────────────────────────────────────────
# Your site domain or numeric ID (e.g. "3dprintedspareparts.com")
WP_SITE_ID=


# ── 4. WordPress.com Bearer Token ─────────────────────────────────────────────
# Obtain via OAuth2 at: https://developer.wordpress.com/apps/
# Full instructions are in the .env file.
WP_TOKEN=


# ── 5. Google Gemini API Key (for Imagen featured image generation) ────────────
# Get your key at: https://aistudio.google.com/apikey
# Requires a Google Cloud project with billing enabled for Imagen access.
GEMINI_API_KEY=
